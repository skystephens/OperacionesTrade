# Copiar este archivo como .env y completar los valores

# Webhook de Make.com para señales Telegram
VITE_MAKE_WEBHOOK_URL=

# IA para análisis de velas (tab IA 🤖)
# Opción 1 — Groq (recomendado: rápido y preciso)
VITE_GROQ_API_KEY=
VITE_AI_PROVIDER=groq
# Modelos: llama-3.3-70b-versatile

# Opción 2 — Gemini (gratuito)
# VITE_GEMINI_API_KEY=
# VITE_AI_PROVIDER=gemini
# Modelos: gemini-2.0-flash

# Otros servicios
VITE_APIFY_API_KEY=
VITE_CLAUDE_API_KEY=
VITE_AIRTABLE_API_KEY=
VITE_AIRTABLE_BASE_ID=
